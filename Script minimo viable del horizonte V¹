# ============================
# 3. Funciones de extracción de texto según extensión
# ============================
def extract_text(filepath):
    ext = os.path.splitext(filepath)[1].lower()
    text = ""
    try:
        if ext == '.pdf':
            import pdfplumber
            with pdfplumber.open(filepath) as pdf:
                for page in pdf.pages:
                    page_text = page.extract_text()
                    if page_text:
                        text += page_text
        elif ext in ['.html', '.htm']:
            from bs4 import BeautifulSoup
            with open(filepath, 'r', encoding='utf-8', errors='ignore') as f:
                soup = BeautifulSoup(f, 'html.parser')
                text = soup.get_text()
        elif ext == '.txt':
            with open(filepath, 'r', encoding='utf-8', errors='ignore') as f:
                text = f.read()
        elif ext == '.md':
            with open(filepath, 'r', encoding='utf-8', errors='ignore') as f:
                text = f.read()
        else:
            # Intentar leer como texto plano
            with open(filepath, 'r', encoding='utf-8', errors='ignore') as f:
                text = f.read()
    except Exception as e:
        # print(f"⚠️ Error leyendo {filepath}: {e}")
        pass
    return text

# ============================
# 4. Segmentación en bloques significativos
# ============================
def segment_blocks(text, min_len=80):
    """Divide por dobles saltos de línea y descarta bloques muy cortos."""
    blocks = re.split(r'\n\s*\n', text)
    return [b.strip() for b in blocks if len(b.strip()) >= min_len]

