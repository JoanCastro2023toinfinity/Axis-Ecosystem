# ============================
# 6. Función de clasificación de un bloque
# ============================
def classify_block(block):
    block_lower = block.lower()
    categories = []
    for cat, words in KEYWORDS.items():
        if any(w in block_lower for w in words):
            categories.append(cat)
    # Si no coincide con ninguna, se asigna a "excedentes"
    if not categories:
        categories = ["excedentes"]
    return categories

# ============================
# 7. Extracción de entidades específicas por categoría
# ============================
def extract_entities(block, category):
    entities = {}
    if category == "legal_financiero":
        # Montos USD
        usd = re.findall(r'USD?\s*[\$]?\s*([\d,]+(?:\.\d+)?)', block, re.I)
        # Porcentajes
        pct = re.findall(r'(\d+(?:\.\d+)?)\s*%', block)
        # Estructuras legales
        legal = re.findall(r'\b(LLC|SAS|S\.A\.|S\.R\.L\.|Offshore|Fiduciaria|Fideicomiso)\b', block, re.I)
        entities = {
            "usd_mounts": usd,
            "percentages": pct,
            "legal_structures": list(set(legal))
        }
    elif category == "operaciones":
        # Herramientas conocidas
        tools = re.findall(r'\b(Brevo|HubSpot|Silgo|Slack|Asana|Trello|Zapier|Sales Navigator|Gemini|ChatGPT|DeepSeek|Claude)\b', block, re.I)
        entities["tools"] = list(set(tools))
        # KPIs / OKRs (palabras seguidas de número)
        kpis = re.findall(r'\b(KPI|OKR|ratio|tasa|conversión)\s*:?\s*(\d+(?:\.\d+)?%?)', block, re.I)
        entities["kpi_examples"] = kpis[:5]
    elif category == "adquisiciones":
        ratios = re.findall(r'(\d+(?:\.\d+)?)\s*%?\s*(?:cierre|conversión|close)', block, re.I)
        entities["close_ratios"] = ratios
    return entities

# ============================
# 8. Procesamiento principal: recorrer archivos
# ============================
all_files = glob.glob(os.path.join(BASE_DIR, "**", "*.*"), recursive=True)
print(f"📄 Archivos encontrados: {len(all_files)}")

results = []  # cada elemento: (archivo, categoria, fragmento, entidades)

for idx, filepath in enumerate(all_files):
    if idx % 50 == 0:
        print(f"Procesando {idx+1}/{len(all_files)}...")
    fname = os.path.basename(filepath)
    text = extract_text(filepath)
    if not text.strip():
        continue
    blocks = segment_blocks(text)
    for block in blocks:
        cats = classify_block(block)
        for cat in cats:
            ent = extract_entities(block, cat) if cat in ["legal_financiero", "operaciones", "adquisiciones"] else {}
            results.append({
                "archivo": fname,
                "ruta_completa": filepath,
                "categoria": cat,
                "fragmento": block[:600],   # preview
                "entidades": ent
            })

print(f"✅ Bloques clasificados: {len(results)}")

