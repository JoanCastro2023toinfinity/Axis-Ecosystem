vertical_keywords = {
    "Splendor": ["splendor", "talent as a service", "pool talent", "closer"],
    "Renasci": ["renasci", "ceo", "vp", "sms al ceo", "upfront"],
    "Axis": ["axis", "clarity advisor", "criterio", "axis ecosystem"],
    "Vita Boma": ["vita boma", "hedging", "trading", "spy options"],
    "Fractalis": ["fractalis", "fractal", "ong", "capitalismo consciente"],
    "JJ Company": ["jj company", "remates", "fideicomiso", "jj co"],
    "Singularity": ["singularity", "negociaciones de elite", "cisnes negros"],
    "Shaddai": ["shaddai", "franquicia"],
    "WITT": ["witt"]
}

def detect_vertical_from_text(text_chunk):
    text_lower = text_chunk.lower()
    for vert, keys in vertical_keywords.items():
        if any(k in text_lower for k in keys):
            return vert
    return "Otro"

# Asignar vertical a cada archivo (usando el primer fragmento o el nombre)
df['vertical'] = df['archivo'].apply(lambda x: detect_vertical_from_text(x))
# Refinar con el contenido de fragmentos (opcional)
for idx, row in df.iterrows():
    if row['vertical'] == "Otro":
        vert = detect_vertical_from_text(row['fragmento'])
        df.at[idx, 'vertical'] = vert

# Tabla resumen: conteo de categorías por vertical
